{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": [
        "FROM (?<depName>[^:]+):(?<currentValue>[^@\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.+\\.yml$"],
      "matchStrings": [
        "uses: (?<depName>[^@]+)@(?<currentDigest>[a-f0-9]{40}) # (?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "github-tags",
      "digestValueTemplate": "{{#if isPinDigest}}{{{newDigest}}}{{else}}{{{currentDigest}}}{{/if}}"
    }
  ]
}
